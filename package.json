{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "eldyl-dev",
  "license": "GPL-3.0-only",
  "description": "A minimal portfolio site built with Astro and Tailwind.",
  "homepage": "https://eldyl.dev",
  "repository": "https://github.com/eldyl/eldyl.dev",
  "bugs": {
    "url": "https://github.com/eldyl/eldyl.dev/issues"
  },
  "author": {
    "name": "Dylan Ullrich",
    "email": "dylan@eldyl.dev",
    "url": "https://eldyl.dev"
  },
  "type": "module",
  "version": "0.0.2",
  "packageManager": "pnpm@10.29.2",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "postinstall": "pnpm run telemetry",
    "dev": "wrangler types && astro dev",
    "build": "wrangler types && astro check && astro build",
    "preview": "wrangler types && astro preview",
    "bp": "wrangler types && astro check && astro build && astro preview",
    "deploy-site": "wrangler types && astro check && astro build && wrangler deploy",
    "astro": "astro",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint 'src/**/*.{js,ts,astro}'",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "telemetry": "astro telemetry disable && wrangler telemetry disable"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.8",
    "@astrojs/cloudflare": "^13.1.8",
    "@astrojs/sitemap": "^3.7.2",
    "@astrojs/ts-plugin": "^1.10.7",
    "@playform/compress": "^0.2.3",
    "@tailwindcss/vite": "^4.2.2",
    "astro": "^6.1.5",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-slug": "^6.0.0",
    "remark-toc": "^9.0.0",
    "satori-astro": "^0.4.0",
    "satori-html": "^0.3.2",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^25.6.0",
    "@typescript-eslint/parser": "^8.58.1",
    "@vitest/coverage-v8": "^4.1.4",
    "astro-icon": "^1.1.5",
    "eslint": "^10.2.0",
    "eslint-plugin-astro": "^1.7.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "prettier": "3.8.1",
    "prettier-plugin-astro": "0.14.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.1",
    "vite": "^7.3.2",
    "vitest": "^4.1.4",
    "wrangler": "^4.81.1"
  }
}
