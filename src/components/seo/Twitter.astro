---
// https://developer.x.com/en/docs/x-for-websites/cards/overview/abouts-cards
import type { TwitterCardType } from "./types";

interface Props {
  type?: TwitterCardType;
  title?: string;
  description?: string;
  image?: URL;
}

const { type = "summary_large_image", title, description, image } = Astro.props;
---

{type && <meta name="twitter:card" content={type} />}
{title && <meta name="twitter:title" content={title} />}
{description && <meta name="twitter:description" content={description} />}
{image && <meta name="twitter:image" content={image} />}
