---
import "@/styles/global.css";

import type { ComponentProps } from "astro/types";
import { getCollection } from "astro:content";
import { Icon } from "astro-icon/components";

import { BASE_TEN, NAME } from "@/constants";
import Head from "@/components/Head.astro";
import { base_path } from "@/utils";
import { get_page_entry } from "@/utils/collections";

type HeadProps = ComponentProps<typeof Head>;

interface Props extends HeadProps {
  h1?: string;
}

const pages = (await getCollection("pages")).sort(
  (a, b) => a.data.order.valueOf() - b.data.order.valueOf(),
);
const links = (await getCollection("links")).sort(
  (a, b) =>
    parseInt(a.id.valueOf(), BASE_TEN) - parseInt(b.id.valueOf(), BASE_TEN),
);

const path = Astro.url.pathname;

const page_data = get_page_entry(path, pages);

const {
  h1,
  title = page_data?.data.title,
  description = page_data?.data.description,
  seo = null,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <Head
    title={title}
    description={description}
    seo={{
      og: {
        title,
        optional: {
          description,
          ...seo?.og?.optional,
        },
        ...seo?.og,
      },
      ...seo,
    }}
  >
    <slot name="head" />
  </Head>
  <body
    class="bg-background flex min-h-screen flex-col text-zinc-100 antialiased"
  >
    <header class="z-50 flex ring ring-zinc-400/20">
      <nav
        class="mx-auto flex w-full max-w-5xl flex-col items-center justify-between gap-y-8 px-2 py-4 text-xl sm:h-14 sm:flex-row sm:gap-y-0 sm:py-0 sm:text-2xl"
      >
        <div class="flex items-center gap-3">
          {
            pages.map((page) => (
              <a
                href={page.data.href}
                class={
                  base_path(path) === base_path(page.data.href)
                    ? "bg-accent-faded rounded px-2 text-shadow-cyan-200 hover:text-shadow-lg/40"
                    : "px-2 text-shadow-cyan-200 hover:text-shadow-lg/40"
                }
              >
                {page.id}
              </a>
            ))
          }
        </div>
        <div class="flex items-center gap-6">
          {
            links.map((link) => (
              <a
                href={link.data.href}
                target="_blank"
                rel="noopener noreferrer"
              >
                <Icon
                  class="hover:text-accent"
                  title={link.data.name}
                  name={link.data.name}
                />
              </a>
            ))
          }
        </div>
      </nav>
    </header>
    <main class="grow">
      <div class="mx-auto mt-16 w-full max-w-5xl px-6 sm:mt-32">
        {
          h1 ? (
            <>
              <header>
                <h1 class="text-4xl leading-tight font-bold tracking-tight sm:text-5xl">
                  {h1}
                </h1>
                {description && (
                  <p class="text-subheading mt-6 text-base">{description}</p>
                )}
              </header>
              <div class="mt-16 sm:mt-20">
                <slot />
              </div>
            </>
          ) : (
            <slot />
          )
        }
      </div>
    </main>
    <footer class="mt-16 flex flex-col items-center justify-center">
      <div class="w-6 rounded border-t-4 border-zinc-400/20"></div>
      <div class="py-6">
        <span>&copy; {new Date().getFullYear()} {NAME}</span>
      </div>
    </footer>
  </body>
</html>
